{
  "id": "",
  "name": "20 日新高突破",
  "enabled": true,
  "description": "收盘价 > 过去 20 日（不含今日）最高价时触发",
  "asset_source": {"type": "inline", "assets": [], "disabled_tickers": []},
  "signal": {
    "category": {"direction": "buy", "label": "突破", "description": "突破近 20 日新高，动量买入"},
    "formulas": [
      {"name": "资产池收盘价", "expression": "资产池构造({ASSETS}) * \"全市场每日收盘价（分钟刷新）\""},
      {"name": "前20日高",     "expression": "最大值(NDay(\"资产池收盘价\", 1), 20)"},
      {"name": "信号",         "expression": "\"资产池收盘价\" > \"前20日高\""}
    ],
    "trigger_formula": "信号",
    "display_fields": ["资产池收盘价", "前20日高"],
    "lookback_days": 60
  },
  "cooldown_days": 7,
  "analysis_hook": {"enabled": false, "framework_doc": "", "websearch_template": {}, "output_sections": []},
  "notification": {
    "wecom": {"enabled": true, "webhook": "", "mentioned_list": [], "mentioned_mobile_list": []},
    "push_when": "triggered_only"
  },
  "schedule": {"enabled": true, "time": "16:00", "cron": null, "task_name": ""},
  "report": {"template_path": "../../templates/default_report.md", "output_dir": "output/reports"}
}
